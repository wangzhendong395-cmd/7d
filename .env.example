# Optional: Feishu incoming webhook for group push notifications.
FEISHU_WEBHOOK_URL=

# Optional: Feishu app bot config for group command replies.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=

# Optional: SEC recommends a descriptive User-Agent.
SEC_USER_AGENT=7D Event Radar contact@example.com

# Optional: local web server port. 7317 avoids conflicts with common localhost:3000 apps.
# If this port is occupied, local dev automatically tries the next available port.
PORT=7317

# Optional: Futu OpenAPI. Start Futu OpenD locally first.
FUTU_ENABLED=
FUTU_OPEND_HOST=127.0.0.1
FUTU_OPEND_PORT=11111

# Optional: Tiger OpenAPI. Keep credentials read-only in this app.
TIGER_ENABLED=
TIGER_CLIENT_ID=
TIGER_ACCOUNT=
TIGER_PRIVATE_KEY_PATH=
TIGER_LICENSE=
TIGER_SANDBOX=true

# Optional: Interactive Brokers TWS / IB Gateway API.
IBKR_ENABLED=
IBKR_TWS_HOST=127.0.0.1
IBKR_TWS_PORT=7497
IBKR_MODE=paper

# Optional: Chief Securities. Only official API URLs should be used.
CHIEF_ENABLED=
CHIEF_OFFICIAL_API_URL=
CHIEF_API_NOTE=
